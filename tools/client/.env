# ============================================
# 音频异常检测客户端监控配置文件
# ============================================

# 服务器地址（修改为你的服务器IP/域名）
ASD_SERVER_URL=http://localhost:8004
ASD_WS_URL=ws://localhost:8004

# 监控目录路径（自动检测新增音频文件）
ASD_MONITOR_DIR=/home/zhouchenghao/PycharmProjects/ASD_for_SPK/原始数据/歌曲/TL-SPK3A20PG 1.0

# 客户端名称（用于在服务端标识此客户端）
ASD_CLIENT_NAME=客户端-1

# 可选：指定客户端ID（默认自动生成）
# ASD_CLIENT_ID=my-client-001

# 日志配置
ASD_LOG_LEVEL=INFO
ASD_LOG_FILE=client.log
