# ASD 客户端配置文件示例
# 复制此文件为 .env 并修改配置

# ============================================
# 服务器配置
# ============================================

# 服务器HTTP地址
ASD_SERVER_URL=http://localhost:8004

# WebSocket地址 (通常与HTTP地址相同，只是协议不同)
# ASD_WS_URL=ws://localhost:8004

# ============================================
# 客户端配置
# ============================================

# 客户端名称 (显示在服务端)
ASD_CLIENT_NAME=客户端-01

# 客户端ID (留空则自动生成)
# ASD_CLIENT_ID=

# ============================================
# 监控配置
# ============================================

# 监控目录 (Windows路径格式)
# 注意: Windows路径可以使用正斜杠或双反斜杠
ASD_MONITOR_DIR=./monitor

# 示例 (绝对路径):
# ASD_MONITOR_DIR=C:/Users/Username/Documents/AudioFiles
# ASD_MONITOR_DIR=C:\\Users\\Username\\Documents\\AudioFiles

# ============================================
# 日志配置
# ============================================

# 日志级别: DEBUG, INFO, WARNING, ERROR
ASD_LOG_LEVEL=INFO

# 日志文件路径 (Windows路径格式)
ASD_LOG_FILE=client.log

# ============================================
# 高级配置 (通常不需要修改)
# ============================================

# 最大重试次数
# ASD_MAX_RETRIES=3

# 重试间隔(秒)
# ASD_RETRY_DELAY=5

# 上传超时(秒)
# ASD_UPLOAD_TIMEOUT=300

# 心跳间隔(秒)
# ASD_HEARTBEAT_INTERVAL=30
