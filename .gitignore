# ====================
# 项目特定的忽略规则
# ====================

# 模型文件 (通常很大，不应该提交到git)
*.pth
*.pt
*.h5
*.hdf5
*.pb
*.onnx
*.pkl
*.pickle
*.model
*.weights
*.caffemodel
*.prototxt
*.uff
*.engine
*.plan
*.tflite
*.mlmodel
*.cfg
*.darknet

# 训练输出和检查点
saved_results/
checkpoints/
outputs/
runs/
logs/
weights/
*.ckpt
*.checkpoint

# 数据集（不应该在git中）
dataset/
data/
datasets/
images/
*.zip
*.tar
*.tar.gz
*.gz
*.rar
*.7z

# 音频文件
*.wav
*.mp3
*.flac
*.aac
*.ogg
*.m4a
*.wma
*.aiff
*.au
*.mid
*.midi
*.amr

# 图像文件（如果需要保留示例图像，可以注释掉）
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.tif
*.webp
*.svg
*.ico
*.psd
*.raw
*.cr2
*.nef
*.orf
*.sr2

# 视频文件
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.mkv
*.webm

# 大型二进制文件
*.bin
*.dat
*.dump

# 临时文件
*.tmp
*.temp
*.swp
*.bak
*.backup
*.orig
*.rej

# 结果和可视化
results/
visualization/
vis/
predictions/
inference_output/
roc_curves/
*.roc
*.csv
*.json

# 缓存文件
.cache/
.cache
.cache.*

# 参考文件（可以保留，但忽略生成的）
ref/*.wav  # 只忽略wav，保留其他参考文件

# 切片数据
slice/*

# 预训练模型目录（如果只想保留部分）
pre_trained/*
!pre_trained/README.md  # 保留README

# 模型检查点目录
model_ckpts/*
!model_ckpts/README.md  # 保留README
